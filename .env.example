# =============================================================================
# Client-side config (VITE_ prefix — embedded in browser bundle, NOT secret)
# Copy this to `.env` for local dev.
# =============================================================================

VITE_CHECKOUTCHAMP_PROXY_URL=
VITE_PAPERCLIP_API_URL=/paperclip
VITE_PAPERCLIP_COMPANY_ID=
VITE_WORKER_AGENT_ID=

# Dev-only: lets `npm run dev` reach the upstream paperclip API through the
# Vite proxy. In production, the real token is injected server-side by
# functions/paperclip/[[path]].ts. Do NOT set this as a Cloudflare Pages var.
VITE_PAPERCLIP_API_TOKEN=

# =============================================================================
# Server-side secrets — Cloudflare Pages Secrets
# Set each with: wrangler pages secret put <NAME> --project-name management-dashboard
# (or via the Cloudflare dashboard: Pages → management-dashboard → Settings → Environment variables)
# =============================================================================

# Paperclip (server-side proxy injects these on every upstream call)
#   PAPERCLIP_UPSTREAM_URL   e.g. https://bannister-bullseye-pastel.ngrok-free.dev/api
#                            later: https://paperclip.trustapollo.media/api
#   PAPERCLIP_API_TOKEN

# Auth (JWT signing)
#   JWT_SECRET

# Airtable
#   AIRTABLE_API_KEY
#   AIRTABLE_BASE_ID

# RedTrack
#   REDTRACK_API_KEY
#   REDTRACK_BASE_URL      (optional; defaults to https://api.redtrack.io)

# Facebook Graph
#   FB_APP_ID
#   FB_APP_SECRET

# CheckoutChamp
#   CHECKOUTCHAMP_LOGIN_ID
#   CHECKOUTCHAMP_PASSWORD
